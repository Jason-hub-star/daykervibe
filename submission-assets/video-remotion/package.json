{
  "name": "expedition-hub-video-remotion",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts ExpeditionHubLongform out/expedition-hub-longform.mp4",
    "render:with-audio": "remotion render src/index.ts ExpeditionHubLongform out/expedition-hub-longform-with-audio.mp4 --props='{\"withAudio\":true}'",
    "tts:mac": "node scripts/generate-narration-macos.mjs",
    "voice:sync": "node scripts/sync-reference-voice.mjs",
    "tts:mimika": "node scripts/generate-narration-mimika.mjs",
    "srt:ko": "node scripts/generate-srt.mjs",
    "compositions": "remotion compositions src/index.ts"
  },
  "dependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "remotion": "4.0.434"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.434",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "typescript": "5.9.3"
  }
}
